{
  "name": "spotify-playlist-downloader",
  "version": "0.1.0",
  "description": "Download Spotify playlists as tagged MP3 files",
  "type": "module",
  "bin": {
    "spotifydl": "dist/cli/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "clean": "tsx scripts/clean.ts",
    "build": "tsx scripts/build.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release:check": "tsx scripts/release.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "commander": "^14.0.0",
    "dotenv": "^17.0.0",
    "node-id3": "^0.2.9",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^24.13.3",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}

{
  "name": "spotify-playlist-downloader",
  "version": "0.1.0",
  "description": "Download Spotify playlists as tagged MP3 files",
  "type": "module",
  "bin": { "spotifydl": "dist/cli/index.js" },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "commander": "^14.0.0",
    "dotenv": "^17.0.0",
    "node-id3": "^0.2.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
